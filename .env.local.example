# Copy to .env.local (gitignored) or export these values in your shell.
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_THINKING_MODE=disabled

# Optional local evidence-store overrides.
PRODUCT_TRACE_STORE_DIR=.local-data/product-agent-runs
AGENT_EVAL_TRACE_STORE_DIR=.local-data/agent-eval-agent-runs
PRODUCT_DIAGNOSIS_STORE_DIR=.local-data/product-diagnoses
AGENT_EVAL_DIAGNOSIS_STORE_DIR=.local-data/agent-eval-diagnoses
AGENT_EVAL_STORE_DIR=.local-data/agent-eval-runs
