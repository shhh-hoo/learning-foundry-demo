{
  "name": "learning-foundry-demo",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "demo:local": "tsx scripts/start-local-demo.ts",
    "registry:demo": "tsx scripts/demo-registry-server.ts",
    "agent:gateway": "tsx scripts/agent-gateway-server.ts",
    "policy:audit": "tsx scripts/audit-policy.ts",
    "core:leakage": "vitest run tests/core-leakage.test.ts",
    "agenteval:live": "tsx scripts/agenteval-live.ts",
    "agenteval:checkpoint": "AGENT_EVAL_CHECKPOINT=1 tsx scripts/agenteval-live.ts",
    "agenteval:baseline": "AGENT_EVAL_BASELINE=1 tsx scripts/agenteval-live.ts",
    "agenteval:reliability": "AGENT_EVAL_RELIABILITY=1 tsx scripts/agenteval-live.ts",
    "agenteval:core-contract": "AGENT_EVAL_LAYER=CORE_CONTRACT tsx scripts/agenteval-live.ts",
    "agenteval:reference-pack": "AGENT_EVAL_LAYER=REFERENCE_PACK tsx scripts/agenteval-live.ts",
    "agenteval:generalization": "AGENT_EVAL_LAYER=GENERALIZATION tsx scripts/agenteval-live.ts",
    "agenteval:adversarial": "AGENT_EVAL_LAYER=ADVERSARIAL tsx scripts/agenteval-live.ts",
    "agenteval:learning-loop": "AGENT_EVAL_LAYER=LEARNING_LOOP tsx scripts/agenteval-live.ts",
    "agenteval:retrieval": "AGENT_EVAL_DIMENSION=RETRIEVAL tsx scripts/agenteval-live.ts",
    "agenteval:report": "tsx scripts/agenteval-report.ts",
    "agenteval:compare": "tsx scripts/agenteval-compare.ts",
    "runtime:parity:fixture": "tsx scripts/runtime-parity-fixture.ts",
    "runtime:parity:checkpoint": "RUNTIME_PARITY_SELECTION=CHECKPOINT tsx scripts/runtime-parity.ts",
    "runtime:parity:baseline": "RUNTIME_PARITY_SELECTION=BASELINE tsx scripts/runtime-parity.ts",
    "runtime:parity:layer": "RUNTIME_PARITY_SELECTION=LAYER tsx scripts/runtime-parity.ts",
    "runtime:parity:dimension": "RUNTIME_PARITY_SELECTION=DIMENSION tsx scripts/runtime-parity.ts",
    "runtime:parity:self-check": "tsx scripts/runtime-parity.ts --self-comparison",
    "benchmark:manifest": "node --import tsx scripts/value-benchmark-manifest.ts",
    "benchmark:preflight": "node --import tsx scripts/value-benchmark.ts preflight",
    "benchmark:live": "node --import tsx scripts/value-benchmark.ts run",
    "benchmark:review": "node --import tsx scripts/value-benchmark-review.ts",
    "corpus:ingest": "tsx scripts/corpus-ingest.ts",
    "corpus:inspect": "tsx scripts/corpus-inspect.ts",
    "corpus:export:public": "tsx scripts/corpus-export-public.ts",
    "storyboard": "tsx scripts/capture-storyboard.ts",
    "check": "tsc -b --pretty false",
    "test": "vitest run",
    "build": "tsc -b && vite build",
    "export:components": "tsx scripts/export-components.ts",
    "sync:trainer": "tsx scripts/sync-trainer.ts"
  },
  "dependencies": {
    "ajv": "^8.20.0",
    "katex": "^0.17.0",
    "pdfjs-dist": "^5.6.205",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-markdown": "^10.1.0",
    "rehype-katex": "^7.0.1",
    "remark-math": "^6.0.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "es-module-lexer": "2.3.1",
    "jsdom": "29.1.1",
    "playwright": "^1.61.1",
    "tsx": "4.21.0",
    "typescript": "7.0.2",
    "vite": "8.1.4",
    "vitest": "4.1.10"
  }
}
