# Local/test fallback. Canonical Product State and operational records use separate schemas.
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:55432/learning_foundry

# Required in production. They must use distinct roles or database targets there.
PRODUCT_DATABASE_URL=
CHECKPOINT_DATABASE_URL=

# Product web process: narrow internal client only. Never add the executor DB credential here.
COMPONENT_EXECUTOR_SERVICE_URL=
COMPONENT_EXECUTOR_SERVICE_TOKEN=

# Separate Component Executor process only:
# COMPONENT_EXECUTOR_PRODUCT_DATABASE_URL=
# COMPONENT_EXECUTOR_DATABASE_URL=

# Auth.js. Generate a unique secret for every non-test environment.
AUTH_SECRET=
AUTH_TRUST_HOST=true

# Explicitly isolated local/browser showcase only. Never enable in a production environment.
SYNTHETIC_SHOWCASE_MODE=false
SHOWCASE_PASSWORD=

# Optional provider-backed explanation. Without a key, model synthesis is explicitly unavailable.
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Optional redacted external tracing.
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=learning-foundry-rewrite
